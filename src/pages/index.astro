---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const skills = [
	'Music Production',
	'Marketing Strategy',
	'Multimedia Content',
	'Campaign Execution',
	'Localization Strategy',
	'Artist Relations',
	'Creative Direction',
	'Event Management',
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main class="hero-wrap">
			<section class="hero">
				<div class="hero-text">
					<h1>Noah Zheng</h1>
					<p class="tagline">
						Marketing strategist & creative producer<br />
						working across music and visual arts.
					</p>
				</div>

				<div class="hero-visual">
					<img src="/orange-circle.png" alt="" class="circle" aria-hidden="true" />
					<img src="/noah-photo.png" alt="Noah Zheng" class="photo" />
				</div>
			</section>
		</main>

		<section class="skills" aria-label="Competencies">
			<ul class="skills-list">
				{skills.map((s) => (
					<li class="skill-item">{s}</li>
				))}
			</ul>
		</section>

		<Footer />
	</body>
</html>

<style>
	.hero-wrap {
		min-height: calc(100svh - 62px - 120px);
		max-width: 900px;
		margin: auto;
		padding: 0 1.5em;
		display: flex;
		align-items: center;
	}

	.hero {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 4em;
		padding: 4em 0;
	}

	.hero-text {
		flex: 1;
	}

	.hero h1 {
		font-size: 5.5em;
		font-weight: 300;
		letter-spacing: -0.02em;
		margin-bottom: 1.6em;
	}

	.tagline {
		font-size: 1.05em;
		font-weight: 300;
		color: var(--text-muted);
		line-height: 1.7;
		margin: 0;
	}

	/* Photo composition */
	.hero-visual {
		position: relative;
		flex-shrink: 0;
		width: 340px;
	}

	.photo {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 2px;
		position: relative;
		z-index: 1;
	}

	.circle {
		position: absolute;
		width: 36%;
		height: auto;
		top: -10%;
		left: -12%;
		z-index: 2;
	}

	/* Full-bleed skills — warm grey block */
	.skills {
		width: 100%;
		overflow: hidden;
		background: #e2ddd7;
		padding: 3em 0 5em 1.5rem;
	}

	.skills-list {
		list-style: none;
		padding: 0;
		margin: 0;
		line-height: 0.95;
	}

	.skill-item {
		font-family: var(--font-sans);
		font-size: clamp(1.6em, 2.8vw, 2.6em);
		font-weight: 300;
		color: #1a1917;
		white-space: nowrap;
		transition: color 0.15s ease;
		cursor: default;
		letter-spacing: -0.01em;
	}

	/* Dim all, highlight hovered */
	.skills-list:hover .skill-item {
		color: rgba(26, 25, 23, 0.3);
	}
	.skills-list .skill-item:hover {
		color: #1a1917;
	}

	@media (max-width: 720px) {
		.hero-wrap {
			padding: 2em 1em;
		}
		.hero {
			flex-direction: column-reverse;
			gap: 2.5em;
		}
		.hero h1 {
			font-size: 3.2em;
		}
		.hero-visual {
			width: 80%;
		}
		.skills {
			padding-left: 1rem;
		}
	}
</style>
