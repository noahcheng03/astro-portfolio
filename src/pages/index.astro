---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Noah Zheng</h1>
				<p class="tagline">
					Marketing strategist & creative producer<br />
					working across music and visual arts.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 7em 0 5em;
	}
	.hero h1 {
		font-size: 5.5em;
		font-weight: 300;
		letter-spacing: -0.02em;
		margin-bottom: 0.45em;
	}
	.tagline {
		font-size: 1.05em;
		font-weight: 300;
		color: var(--text-muted);
		line-height: 1.7;
		margin: 0;
		max-width: 420px;
	}
	@media (max-width: 720px) {
		.hero {
			padding: 3.5em 0 2.5em;
		}
		.hero h1 {
			font-size: 3.2em;
		}
	}
</style>
