---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About | Noah Zheng" description="About Noah Zheng — marketing specialist and creative producer." />
	</head>
	<body>
		<Header />
		<main>

			<section class="about-top">
				<div class="about-left">
					<h1>Hi, I'm Noah.</h1>
					<p class="bio-text">
						I'm Noah Zheng, a marketing specialist and creative producer working at the intersection
						of music technology, culture, and digital storytelling. With experience at Arturia leading
						localized marketing, artist relations, content campaigns, and community growth in China, I
						combine strategic brand thinking with hands-on creative production. My background in music
						production, photography, video editing, and cross-cultural communication shapes the way I
						approach projects: visually, culturally, and with a strong sense of audience.
					</p>
				</div>
				<div class="about-photo-wrap">
					<img src="/about-photo.png" alt="Noah Zheng" class="about-photo" />
				</div>
			</section>

			<hr />

			<section class="connect">
				<h2>Connect with me</h2>
				<div class="social-links">
					<a href="https://www.instagram.com/itsnoahzheng/" target="_blank" rel="noopener noreferrer" class="social-btn">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
							<circle cx="12" cy="12" r="4"/>
							<circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
						</svg>
						Instagram
					</a>
					<a href="https://www.xiaohongshu.com/user/profile/5d25edc50000000012008317?xsec_token=ABplRYGbO1W71zuLgpeyi9mYOgjzW4Y69esz9lsQmi9Bc%3D&xsec_source=pc_search" target="_blank" rel="noopener noreferrer" class="social-btn">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
						</svg>
						小红书
					</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.about-top {
		display: flex;
		align-items: flex-start;
		gap: 4em;
		padding: 4em 0 2.5em;
	}

	.about-left {
		flex: 1;
		min-width: 0;
	}

	.about-left h1 {
		font-size: 4.5em;
		font-weight: 300;
		letter-spacing: -0.02em;
		margin-bottom: 0.6em;
	}

	.bio-text {
		font-size: 1.05em;
		font-weight: 300;
		line-height: 1.85;
		margin: 0;
		color: var(--text);
	}

	.about-photo-wrap {
		flex-shrink: 0;
		width: 260px;
	}

	.about-photo {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 2px;
		object-fit: cover;
	}

	hr {
		margin: 1em 0 3em;
	}

	.connect h2 {
		font-size: 1em;
		font-family: var(--font-sans);
		font-weight: 400;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 1.5em;
	}

	.social-links {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}

	.social-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.65em 1.3em;
		border: 1px solid var(--border);
		color: var(--text);
		text-decoration: none;
		font-size: 0.8em;
		font-weight: 400;
		letter-spacing: 0.06em;
		transition: border-color 0.2s ease, color 0.2s ease;
	}

	.social-btn:hover {
		border-color: var(--text);
		text-decoration: none;
	}

	@media (max-width: 720px) {
		.about-top {
			flex-direction: column;
			gap: 2em;
		}
		.about-left h1 {
			font-size: 3em;
		}
		.about-photo-wrap {
			width: 100%;
		}
	}
</style>
