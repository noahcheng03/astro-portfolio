---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Projects | Noah Zheng" description="Selected projects by Noah Zheng across music, photography, and videography." />
		<script async src="https://www.instagram.com/embed.js"></script>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>

			<div class="jump-nav">
				<a href="#music" class="jump-btn">Music</a>
				<a href="#videography" class="jump-btn">Videography</a>
				<a href="#photography" class="jump-btn">Photography</a>
			</div>

			<section id="music">
				<h2>Music</h2>
				<p>
					Music has always been at the heart of what I do. With a background in game score
					production for NetEase Games and years of work behind the scenes as a ghost producer,
					I've had the privilege of shaping sounds across genres and platforms. That experience
					culminated in projects like <em>Nefelibata 2</em> with Chinese artist 曾柯淳 — a
					collaboration that reached over 40 million streams both domestic and worldwide.
				</p>
				<div class="latest-project">
					<span class="latest-label">Latest Project</span>
					<div class="player-wrap">
						<iframe src="https://embed.music.apple.com/us/album/dream-of-u/1828411582?i=1828411613" width="100%" height="150" frameborder="0" allow="autoplay; encrypted-media" sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation"></iframe>
					</div>
					<p class="credit">Credits: producer, arranger</p>
				</div>
				<a href="https://www.instagram.com/itsnoahzheng/" target="_blank" rel="noopener noreferrer" class="ig-link">More on Instagram ↗</a>
			</section>

			<section id="videography">
				<h2>Videography</h2>
				<p class="section-desc">Full stack video production.</p>

				<!-- Instagram short-form: horizontal scroll -->
				<span class="reel-label">Short Form</span>
				<div class="reel-scroll">
					<div class="reel-track">
						<div class="reel-item">
							<blockquote
								class="instagram-media"
								data-instgrm-permalink="https://www.instagram.com/p/DSIa8yWjYAQ/"
								data-instgrm-version="14"
								style="background:#f6f3ee;border:0;border-radius:2px;box-shadow:none;margin:0;min-width:100%;padding:0;width:100%;"
							></blockquote>
							<p class="video-credit">Original music, video production</p>
						</div>
						<div class="reel-item">
							<blockquote
								class="instagram-media"
								data-instgrm-permalink="https://www.instagram.com/p/DSu1T9NDmv0/"
								data-instgrm-version="14"
								style="background:#f6f3ee;border:0;border-radius:2px;box-shadow:none;margin:0;min-width:100%;padding:0;width:100%;"
							></blockquote>
							<p class="video-credit">Original music, video production</p>
						</div>
					</div>
				</div>

				<!-- Long-form: 2×2 grid -->
				<span class="reel-label" style="margin-top:2.5em;">Long Form</span>
				<div class="video-grid">
					<div class="video-item">
						<div class="video-frame">
							<iframe
								src="https://www.youtube.com/embed/OWzPu4s45ik?rel=0&modestbranding=1"
								title="Colorist"
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							></iframe>
						</div>
						<p class="video-credit">Colorist</p>
					</div>
					<div class="video-item">
						<div class="video-frame">
							<iframe
								src="https://www.youtube.com/embed/ZcXasPtOtEc?rel=0&modestbranding=1"
								title="Camera operator, Colorist"
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							></iframe>
						</div>
						<p class="video-credit">Camera operator, Colorist</p>
					</div>
					<div class="video-item">
						<div class="video-frame">
							<iframe
								src="https://www.youtube.com/embed/24RviPTzGvc?rel=0&modestbranding=1"
								title="DP, Editing Supervisor, Director, Colorist"
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							></iframe>
						</div>
						<p class="video-credit">DP, Editing Supervisor, Director, Colorist</p>
					</div>
					<div class="video-item">
						<div class="video-frame">
							<iframe
								src="https://player.bilibili.com/player.html?bvid=BV1qjkiBiEGa&page=1&high_quality=1&danmaku=0"
								title="Director, DP, Colorist"
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
								scrolling="no"
							></iframe>
						</div>
						<p class="video-credit">Director, DP, Colorist</p>
					</div>
				</div>

				<a href="https://www.instagram.com/itsnoahzheng/" target="_blank" rel="noopener noreferrer" class="ig-link">More on Instagram ↗</a>
			</section>

			<section id="photography">
				<h2>Photography</h2>
				<div class="photo-scroll">
					<div class="photo-track">
						{Array.from({length: 20}, (_, i) => i + 1).map((n) => (
							<img src={`/photography/${n}.jpg`} alt={`Photography ${n}`} class="photo-slide" />
						))}
					</div>
				</div>
				<a href="https://www.instagram.com/itsnoahzheng/" target="_blank" rel="noopener noreferrer" class="ig-link">More on Instagram ↗</a>
			</section>

		</main>
		<Footer />
	</body>
</html>


<style>
	h1 {
		margin-bottom: 1em;
	}

	.jump-nav {
		display: flex;
		gap: 0.75em;
		margin-bottom: 4em;
		flex-wrap: wrap;
	}

	.jump-btn {
		display: inline-block;
		padding: 0.55em 1.3em;
		border: 1px solid var(--border);
		color: var(--text);
		text-decoration: none;
		font-size: 0.75em;
		font-weight: 400;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		transition: border-color 0.2s ease, background 0.2s ease;
	}

	.jump-btn:hover {
		border-color: var(--text);
		text-decoration: none;
	}

	section {
		padding: 3em 0;
		border-top: 1px solid var(--border);
		scroll-margin-top: 80px;
	}

	section h2 {
		font-size: 2em;
		font-weight: 300;
		margin-bottom: 1em;
	}

	section p {
		font-size: 1.05em;
		font-weight: 300;
		line-height: 1.85;
		max-width: 620px;
	}

	section em {
		font-family: var(--font-serif);
		font-style: italic;
	}

	.latest-project {
		margin-top: 2.5em;
		max-width: 480px;
	}

	.latest-label {
		display: block;
		font-size: 0.65em;
		font-weight: 400;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 1em;
	}

	.player-wrap {
		border: 1px solid var(--border);
		border-radius: 2px;
		overflow: hidden;
		margin-bottom: 0.6em;
	}

	.player-wrap iframe {
		display: block;
		border-radius: 0 !important;
	}

	.credit {
		margin: 0.75em 0 0;
		font-size: 0.72em !important;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		font-style: italic;
	}

	.placeholder-note {
		font-size: 0.75em !important;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
		padding: 2em 0;
		margin: 0;
	}

	.video-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.2em 1.5em;
		margin-bottom: 1.5em;
	}

	.video-item {
		min-width: 0;
	}

	.reel-label {
		display: block;
		font-size: 0.65em;
		font-weight: 400;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 1em;
	}

	.reel-scroll {
		overflow-x: auto;
		overflow-y: hidden;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
		cursor: grab;
		margin-bottom: 0.5em;
	}

	.reel-scroll::-webkit-scrollbar { display: none; }
	.reel-scroll:active { cursor: grabbing; }

	.reel-track {
		display: flex;
		gap: 1em;
		align-items: flex-start;
	}

	.reel-item {
		flex-shrink: 0;
		width: 300px;
	}

	.reel-item .instagram-media {
		border-radius: 2px !important;
	}

	.video-frame {
		position: relative;
		width: 100%;
		padding-top: 56.25%;
		border: 1px solid var(--border);
		border-radius: 2px;
		overflow: hidden;
	}

	.video-frame iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		display: block;
	}

	.video-credit {
		margin: 0.6em 0 0;
		font-size: 0.72em;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		font-style: italic;
	}

	.photo-scroll {
		overflow-x: auto;
		overflow-y: hidden;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: none;
		cursor: grab;
		margin: 0 -1.5em;
		padding: 0 1.5em;
	}

	.photo-scroll::-webkit-scrollbar {
		display: none;
	}

	.photo-scroll:active {
		cursor: grabbing;
	}

	.photo-track {
		display: flex;
		gap: 0.75em;
		padding-bottom: 0.5em;
	}

	.photo-slide {
		height: 420px;
		width: auto;
		flex-shrink: 0;
		object-fit: cover;
		border-radius: 2px;
		display: block;
	}

	.ig-link {
		display: inline-block;
		margin-top: 1.8em;
		font-size: 0.75em;
		font-weight: 400;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.ig-link:hover {
		color: var(--text);
		text-decoration: none;
	}

	@media (max-width: 600px) {
		.video-grid {
			grid-template-columns: 1fr;
		}
		.ig-card {
			flex-direction: column;
			gap: 0.5em;
		}
	}

	.section-desc {
		font-size: 1.05em;
		font-weight: 300;
		color: var(--text-muted);
		margin-bottom: 2em;
	}

</style>
