---
// Private 520 page — not linked from nav, noindex
const YOU   = "叁叁";
const ME    = "Noah";
const START = "2019-08-07";
const CITY  = "Nanchang & Shanghai";

const things = [
  "how you bring out the best of me",
  "your support and love when i'm feeling down",
  "your 健胃消食片 when i had too much for dinner",
  "how you always find the best places and activities for the two of us",
  "you, in the morning, before the world has asked anything of you",
];

const letterParas = [
  "There is a private kind of weather between two people. Ours is warm, with low afternoon light, and you carry it with you everywhere.",
  "This little corner of the internet is just for us. No one else will find it. I made it on a quiet evening, thinking about how lucky I am, and how strange it is that the universe sometimes arranges itself perfectly. Happy 520. I love you in every language we have, and a few we don't.",
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>520 · For you</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Floating hearts layer -->
<div class="heart-layer" aria-hidden="true" id="heart-layer"></div>

<div class="shell">

  <!-- Topbar -->
  <div class="topbar">
    <div class="mark">5 · 20</div>
    <div class="top-right">
      <div class="caps"><span class="dot"></span>private — not indexed</div>
      <div class="caps" id="topbar-date">{CITY} · May 20</div>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="intro">
      <div class="eyebrow"><span class="dot"></span>a little page for us</div>
      <h1>Happy <span class="ital">520</span><span class="tiny-heart">♥</span></h1>
      <p class="lede">For the person who makes ordinary days feel like something <em>worth saving</em>.</p>
      <div class="signature">— {ME}, <span class="sig-for">for {YOU}</span></div>
    </div>

    <figure class="photo-card">
      <div class="corner-tape"></div>
      <div class="frame">
        <img src="/happy-520.png" alt={`A polaroid of ${ME} and ${YOU}`} class="hero-photo" />
      </div>
      <figcaption></figcaption>
      <div class="stamp">5 · 20 · {year}</div>
    </figure>
  </section>

  <!-- i. Five-Two-Zero -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="num">i.</div>
        <div class="caps" style="margin-top:6px">a translation</div>
      </div>
      <div>
        <h2>Why <em>five-twenty</em>.</h2>
        <p class="kicker">
          In Mandarin, <span class="sc rose-d">五二零</span> (wǔ èr líng) sounds almost exactly like
          <span class="sc rose-d">我爱你</span> (wǒ ài nǐ) — "I love you." So May 20 became a quiet, modern Valentine's Day.
        </p>
      </div>
    </div>

    <div class="fivetwozero">
      <div class="glyph-card">
        <div class="corner">No. 01</div>
        <div class="number">5</div>
        <div class="arrow">↓ sounds like</div>
        <div class="hanzi">我</div>
        <div class="pinyin">wǒ</div>
        <div class="gloss">i</div>
      </div>
      <div class="glyph-card">
        <div class="corner">No. 02</div>
        <div class="number">2</div>
        <div class="arrow">↓ sounds like</div>
        <div class="hanzi">爱</div>
        <div class="pinyin">ài</div>
        <div class="gloss">love</div>
      </div>
      <div class="glyph-card">
        <div class="corner">No. 03</div>
        <div class="number">0</div>
        <div class="arrow">↓ sounds like</div>
        <div class="hanzi">你</div>
        <div class="pinyin">nǐ</div>
        <div class="gloss">you</div>
      </div>
    </div>

    <p class="together-line">
      Five. Two. Zero. <em>Wǒ </em><span class="hanzi-inline">爱</span><em> nǐ.</em>
      &nbsp;<span class="together-aside">— and I do, every day.</span>
    </p>
  </section>

  <!-- ii. Counter -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="num">ii.</div>
        <div class="caps" style="margin-top:6px">a small count</div>
      </div>
      <div>
        <h2>Days, so far.</h2>
        <p class="kicker">Counting from the day we decided this — but really, we both know it started before that.</p>
      </div>
    </div>

    <div class="counter-wrap">
      <div class="big-counter">
        <span id="counter-days">—</span><span class="unit">days</span>
      </div>
      <div class="counter-meta">
        <div class="row">
          <span class="clabel">Began</span>
          <span class="value italic" id="counter-began">—</span>
        </div>
        <div class="row">
          <span class="clabel">In weeks</span>
          <span class="value italic" id="counter-weeks">—</span>
        </div>
        <div class="row">
          <span class="clabel">In months</span>
          <span class="value italic" id="counter-months">—</span>
        </div>
        <div class="row">
          <span class="clabel" id="counter-milestone-label">Until 1000</span>
          <span class="value italic" id="counter-milestone-val">—</span>
        </div>
      </div>
    </div>
  </section>

  <!-- iii. Things I love -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="num">iii.</div>
        <div class="caps" style="margin-top:6px">an unfinished list</div>
      </div>
      <div>
        <h2>Things I love <em>about you</em>.</h2>
        <p class="kicker">Not the big ones. The small, specific ones — the ones that would be obvious to no one but me.</p>
      </div>
    </div>

    <div class="things">
      <div class="things-stage" aria-live="polite">
        {things.map((item, i) => (
          <div class={`thing${i === 0 ? ' active' : ''}`} data-idx={i}>
            <div class="tidx">No. {String(i + 1).padStart(2, '0')} / {String(things.length).padStart(2, '0')}</div>
            <div class="tbody">{item}</div>
          </div>
        ))}
      </div>
      <div class="things-controls">
        <div class="things-dots">
          {things.map((_, i) => (
            <button class={`dot-btn${i === 0 ? ' active' : ''}`} data-idx={i} aria-label={`Show item ${i + 1}`}></button>
          ))}
        </div>
        <div class="things-nav">
          <button class="nav-btn" id="things-prev">← prev</button>
          <button class="nav-btn" id="things-next">next →</button>
        </div>
      </div>
    </div>
  </section>

  <!-- iv. Letter -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="num">iv.</div>
        <div class="caps" style="margin-top:6px">a sealed note</div>
      </div>
      <div>
        <h2>For your eyes <em>only</em>.</h2>
        <p class="kicker">Press the seal.</p>
      </div>
    </div>

    <div class="letter">
      <div class="envelope" id="envelope">
        <div class="flap"></div>
        <div class="seal" id="seal" role="button" aria-label="Open letter" tabindex="0">爱</div>
        <div class="env-body">
          <div class="note-content">
            {letterParas.map((p) => <p>{p}</p>)}
            <div class="sign">— yours, always.</div>
          </div>
          <div class="env-hint" id="env-hint">
            addressed: <span class="rose">{YOU}</span> &nbsp;·&nbsp; from: {ME}
          </div>
        </div>
      </div>
      <div class="envelope-meta">
        <span>postmarked · 5.20</span>
        <span id="env-status">sealed</span>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <div class="foot">
    <span>made quietly, for {YOU} ♥</span>
    <button class="heart-cta" id="heart-cta">send a heart →</button>
  </div>

</div>
</body>
</html>

<style>
  :root {
    --bg:      #f3ece5;
    --bg-soft: #faf4ee;
    --paper:   #fbf6f1;
    --ink:     #1a1917;
    --ink-2:   #3a342f;
    --muted:   #7a6b63;
    --line:    #d8cabf;
    --rose:    #b87783;
    --rose-d:  #8a4d56;
    --blush:   #e7d8d9;
    --cream:   #efe3d6;

    --serif: 'Cormorant Garamond', 'Iowan Old Style', Georgia, serif;
    --sans:  'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif;
    --mono:  'JetBrains Mono', ui-monospace, Menlo, monospace;
    --sc:    'Noto Serif SC', var(--serif);
  }

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: "";
    position: fixed; inset: 0;
    pointer-events: none;
    z-index: 1000;
    background-image: radial-gradient(rgba(26,25,23,0.035) 1px, transparent 1px);
    background-size: 3px 3px;
    mix-blend-mode: multiply;
    opacity: 0.5;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    display: inline-flex;
    align-items: center;
  }
  .caps {
    font-family: var(--mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .sc { font-family: var(--sc); font-style: normal; }
  .rose-d { color: var(--rose-d); }
  .rose { color: var(--rose); }
  .italic { font-style: italic; }

  /* Shell */
  .shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 56px 48px 120px;
    position: relative;
  }

  /* Dot */
  .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--rose);
    display: inline-block;
    vertical-align: middle;
    margin-right: 8px;
    animation: pulse 2.6s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }

  /* Topbar */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 64px;
  }
  .topbar .mark {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--ink);
  }
  .top-right { display: flex; gap: 28px; align-items: baseline; }

  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
    min-height: 64vh;
    padding-bottom: 64px;
  }
  .hero h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(96px, 14vw, 196px);
    line-height: 0.86;
    letter-spacing: -0.04em;
    margin: 20px 0 0;
    color: var(--ink);
  }
  .hero h1 .ital {
    font-style: italic;
    color: var(--rose-d);
    display: inline-block;
    transform: translateY(0.05em);
  }
  .hero h1 .tiny-heart {
    display: inline-block;
    font-size: 0.18em;
    color: var(--rose);
    vertical-align: 0.85em;
    margin-left: 0.08em;
    animation: tinybeat 1.8s ease-in-out infinite;
  }
  @keyframes tinybeat {
    0%, 100% { transform: scale(1); }
    20%       { transform: scale(1.25); }
    40%       { transform: scale(0.95); }
  }
  .hero .lede {
    font-family: var(--serif);
    font-size: 22px;
    line-height: 1.5;
    font-weight: 300;
    color: var(--ink-2);
    max-width: 460px;
    margin: 36px 0 0;
  }
  .hero .lede em { color: var(--rose-d); font-style: italic; }
  .signature {
    margin-top: 36px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--muted);
  }
  .sig-for {
    font-style: normal;
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.12em;
  }

  /* Polaroid */
  .photo-card {
    position: relative;
    justify-self: end;
    width: min(100%, 460px);
    transform: rotate(1.4deg);
    filter: drop-shadow(0 30px 60px rgba(26,25,23,0.18));
    margin: 0;
  }
  .photo-card::before {
    content: "";
    position: absolute;
    inset: 14px -14px -14px 14px;
    background: var(--blush);
    z-index: 0;
  }
  .photo-card .frame {
    position: relative;
    z-index: 1;
    background: var(--paper);
    padding: 18px 18px 60px;
    border: 1px solid rgba(26,25,23,0.06);
  }
  .hero-photo {
    width: 100%;
    display: block;
    object-fit: cover;
  }
  .corner-tape {
    position: absolute;
    top: -10px; left: 50%;
    transform: translateX(-50%) rotate(-2deg);
    width: 96px; height: 22px;
    background: rgba(184,119,131,0.32);
    z-index: 2;
    border-left: 1px dashed rgba(255,255,255,0.4);
    border-right: 1px dashed rgba(255,255,255,0.4);
  }
  .photo-card figcaption {
    position: relative;
    z-index: 2;
    margin-top: -42px;
    padding: 0 6px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink);
    text-align: center;
  }
  .stamp {
    position: absolute;
    bottom: 14px; right: -16px;
    z-index: 3;
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    color: var(--rose-d);
    border: 1px solid var(--rose);
    padding: 4px 8px;
    background: var(--paper);
    transform: rotate(6deg);
    text-transform: uppercase;
  }

  /* Section */
  .section {
    padding: 80px 0;
    border-top: 1px solid var(--line);
  }
  .section-head {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 48px;
    align-items: start;
    margin-bottom: 56px;
  }
  .num {
    font-family: var(--serif);
    font-style: italic;
    font-size: 26px;
    color: var(--rose);
  }
  .section-head h2 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .section-head h2 em { color: var(--rose-d); }
  .kicker {
    margin-top: 14px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--muted);
    max-width: 520px;
  }

  /* 5-2-0 */
  .fivetwozero {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-left: 288px;
    max-width: calc(100% - 288px);
  }
  .glyph-card {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    padding: 36px 28px 28px;
    position: relative;
    overflow: hidden;
  }
  .glyph-card .number {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 96px;
    line-height: 0.9;
    color: var(--ink);
    letter-spacing: -0.04em;
  }
  .glyph-card .arrow {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    margin: 16px 0 8px;
    letter-spacing: 0.12em;
  }
  .glyph-card .hanzi {
    font-family: var(--sc);
    font-weight: 400;
    font-size: 64px;
    line-height: 1;
    color: var(--rose-d);
  }
  .glyph-card .pinyin {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--ink);
    margin-top: 10px;
  }
  .glyph-card .gloss {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 4px;
  }
  .glyph-card .corner {
    position: absolute;
    top: 14px; right: 16px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--rose);
    letter-spacing: 0.15em;
  }
  .together-line {
    margin-top: 36px;
    margin-left: 288px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 26px;
    color: var(--ink);
    line-height: 1.4;
  }
  .hanzi-inline {
    font-family: var(--sc);
    font-style: normal;
    color: var(--rose-d);
    margin: 0 4px;
  }
  .together-aside { color: var(--muted); font-size: 18px; }

  /* Counter */
  .counter-wrap {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: end;
    margin-left: 288px;
  }
  .big-counter {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(80px, 12vw, 168px);
    line-height: 0.86;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .big-counter .unit {
    font-style: italic;
    color: var(--rose-d);
    font-size: 0.32em;
    margin-left: 0.1em;
    vertical-align: 0.6em;
    letter-spacing: -0.02em;
  }
  .counter-meta { display: grid; gap: 18px; }
  .counter-meta .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .clabel {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .value {
    font-family: var(--serif);
    font-style: italic;
    font-size: 26px;
    color: var(--ink);
  }

  /* Things */
  .things {
    margin-left: 288px;
    display: grid;
    gap: 28px;
  }
  .things-stage {
    position: relative;
    min-height: 280px;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    padding: 56px 64px;
    overflow: hidden;
  }
  .thing {
    position: absolute;
    inset: 56px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 600ms ease, transform 600ms ease;
    pointer-events: none;
  }
  .thing.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .tidx {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--rose);
    letter-spacing: 0.22em;
    margin-bottom: 18px;
  }
  .tbody {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.2;
    color: var(--ink);
    letter-spacing: -0.01em;
    max-width: 680px;
  }
  .things-controls {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-content: space-between;
  }
  .things-dots { display: flex; gap: 10px; }
  .dot-btn {
    width: 10px; height: 10px; border-radius: 50%;
    background: transparent;
    border: 1px solid var(--rose);
    cursor: pointer;
    padding: 0;
    transition: background 200ms ease;
  }
  .dot-btn.active { background: var(--rose); }
  .things-nav { display: flex; gap: 8px; }
  .nav-btn {
    appearance: none;
    background: transparent;
    border: 1px solid var(--line);
    color: var(--ink);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 10px 16px;
    cursor: pointer;
    transition: background 200ms ease, border-color 200ms ease;
  }
  .nav-btn:hover { background: var(--cream); border-color: var(--ink); }

  /* Envelope */
  .letter {
    margin-left: 288px;
    max-width: 720px;
  }
  .envelope {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--line);
  }
  .envelope .flap {
    position: relative;
    height: 80px;
    background: var(--cream);
    clip-path: polygon(0 0, 100% 0, 50% 100%);
    transform-origin: top;
    transition: transform 700ms cubic-bezier(.2, .8, .2, 1);
  }
  .envelope.open .flap { transform: rotateX(-180deg); }
  .seal {
    position: absolute;
    left: 50%; top: 56px;
    width: 56px; height: 56px;
    background: var(--rose);
    border-radius: 50%;
    transform: translateX(-50%);
    display: grid; place-items: center;
    font-family: var(--sc);
    font-size: 24px;
    color: var(--paper);
    box-shadow: 0 6px 18px rgba(184,119,131,0.4);
    cursor: pointer;
    transition: transform 400ms ease, opacity 400ms ease;
    z-index: 4;
  }
  .seal:hover { transform: translateX(-50%) scale(1.04); }
  .envelope.open .seal { opacity: 0; transform: translateX(-50%) scale(0.6); pointer-events: none; }
  .env-body { position: relative; padding: 36px 44px 40px; }
  .note-content {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 22px;
    line-height: 1.65;
    color: var(--ink);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 800ms ease, opacity 600ms ease 200ms;
  }
  .envelope.open .note-content { max-height: 1400px; opacity: 1; }
  .note-content p { margin: 0 0 1em; }
  .note-content p:last-child { margin-bottom: 0; }
  .sign {
    margin-top: 32px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 20px;
    color: var(--rose-d);
    text-align: right;
  }
  .env-hint {
    text-align: center;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 36px 0 8px;
    transition: opacity 300ms ease, max-height 300ms ease;
  }
  .envelope.open .env-hint { opacity: 0; max-height: 0; padding: 0; overflow: hidden; }
  .envelope-meta {
    display: flex;
    justify-content: space-between;
    margin-top: 18px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Hearts */
  .heart-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 999;
    overflow: hidden;
  }

  /* Footer */
  .foot {
    margin-top: 96px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .heart-cta {
    background: transparent;
    border: none;
    color: var(--rose);
    font-family: var(--mono);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 10.5px;
    cursor: pointer;
    padding: 4px 0;
  }
  .heart-cta:hover { color: var(--rose-d); }

  /* Responsive */
  @media (max-width: 880px) {
    .shell { padding: 36px 24px 80px; }
    .topbar { margin-bottom: 36px; }
    .hero { grid-template-columns: 1fr; min-height: auto; padding-bottom: 32px; gap: 36px; }
    .photo-card { justify-self: stretch; width: 100%; transform: rotate(0.8deg); }
    .section { padding: 56px 0; }
    .section-head { grid-template-columns: 1fr; gap: 20px; margin-bottom: 36px; }
    .fivetwozero { grid-template-columns: 1fr; margin-left: 0; max-width: 100%; }
    .together-line, .counter-wrap, .things, .letter { margin-left: 0; }
    .counter-wrap { grid-template-columns: 1fr; gap: 32px; align-items: start; }
    .things-stage { padding: 36px 28px; min-height: 240px; }
    .thing { inset: 36px 28px; }
    .env-body { padding: 28px 24px 32px; }
  }
</style>

<style is:global>
  @keyframes heartfloat {
    0%   { transform: translate(-50%, -50%) scale(0.6) rotate(0deg); opacity: 0; }
    20%  { opacity: 1; }
    100% { transform: translate(-50%, calc(-50% - 180px)) scale(1.1) rotate(var(--rot, 12deg)); opacity: 0; }
  }
  .heart {
    position: fixed;
    color: #b87783;
    font-family: 'Cormorant Garamond', Georgia, serif;
    pointer-events: none;
    user-select: none;
    animation: heartfloat 2400ms ease-out forwards;
  }
</style>

<script define:vars={{ START_DATE: START, N: things.length }}>
  /* ---- Day counter ---- */
  const start = new Date(START_DATE + 'T00:00:00');
  const today = new Date();
  const days  = Math.floor((today - start) / 86400000);
  const weeks = Math.floor(days / 7);
  let months  = (today.getFullYear() - start.getFullYear()) * 12 + (today.getMonth() - start.getMonth());
  if (today.getDate() < start.getDate()) months--;

  const milestones = [365,500,730,1000,1095,1500,1825,2000,2500,3000,3650];
  const next = milestones.find(m => m > days) ?? (Math.ceil(days / 1000) * 1000 + 1000);

  document.getElementById('counter-days').textContent = days.toLocaleString();
  document.getElementById('counter-began').textContent =
    start.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  document.getElementById('counter-weeks').textContent = weeks.toLocaleString();
  document.getElementById('counter-months').textContent = months;
  document.getElementById('counter-milestone-label').textContent = `Until ${next}`;
  document.getElementById('counter-milestone-val').textContent = `${next - days} more`;

  /* Topbar live date */
  const tb = document.getElementById('topbar-date');
  const city = tb.textContent.split(' · ')[0];
  tb.textContent = city + ' · ' + today.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

  /* ---- Things carousel ---- */
  let idx = 0;
  const items   = document.querySelectorAll('.thing');
  const dotBtns = document.querySelectorAll('.dot-btn');

  function goTo(i) {
    items[idx].classList.remove('active');
    dotBtns[idx].classList.remove('active');
    idx = ((i % N) + N) % N;
    items[idx].classList.add('active');
    dotBtns[idx].classList.add('active');
  }

  document.getElementById('things-prev').addEventListener('click', () => goTo(idx - 1));
  document.getElementById('things-next').addEventListener('click', () => goTo(idx + 1));
  dotBtns.forEach((btn, i) => btn.addEventListener('click', () => goTo(i)));
  setInterval(() => goTo(idx + 1), 5000);

  /* ---- Envelope ---- */
  const envelope  = document.getElementById('envelope');
  const seal      = document.getElementById('seal');
  const envStatus = document.getElementById('env-status');

  function toggleEnv() {
    envelope.classList.toggle('open');
    envStatus.textContent = envelope.classList.contains('open')
      ? 'opened — read with care' : 'sealed';
  }
  seal.addEventListener('click', toggleEnv);
  seal.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleEnv(); }
  });

  /* ---- Floating hearts ---- */
  const layer = document.getElementById('heart-layer');

  function spawnHeart(x, y) {
    const el = document.createElement('span');
    el.className = 'heart';
    el.textContent = '♥';
    el.style.left = x + 'px';
    el.style.top  = y + 'px';
    el.style.fontSize = (16 + Math.random() * 16) + 'px';
    el.style.setProperty('--rot', (Math.random() * 30 - 15).toFixed(1) + 'deg');
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 2400);
  }

  document.addEventListener('click', e => {
    if (e.target.closest('button,input,.seal,.envelope')) return;
    spawnHeart(e.clientX, e.clientY);
  });

  document.getElementById('heart-cta').addEventListener('click', () => {
    for (let i = 0; i < 6; i++) {
      setTimeout(() => spawnHeart(
        window.innerWidth - 80 + (Math.random() * 80 - 40),
        window.innerHeight - 80 + (Math.random() * 40 - 20)
      ), i * 90);
    }
  });
</script>
